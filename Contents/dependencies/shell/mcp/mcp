export PATH="$HOME/sh/tools:$PATH"
export PATH="$HOME/sh:$PATH"
cd ~/sh/app/media_compress
source e2s system_config && source e2s config 

if [[ $1 == -c ]]; then
    op config $config_app
elif [[ $1 == -h ]]; then
    cat help
elif [[ $1 == -version ]]; then
     echo $version
else
    export temp=$(multi_file) && mkdir $temp
    ./preprocess "$@"
    rm -r $temp
fi
