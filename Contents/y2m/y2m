#!/bin/sh

set -f  # 禁用路径扩展
export PATH="$HOME/sh/tools:$PATH"
export PATH="$HOME/sh:$PATH"
cd ~/sh/app/youtube2music
source e2s config && source e2s system_config

if [[ $1 == "-version" || $1 == -v ]]; then
    config_opt system_config version
elif [[ $1 == -h ]]; then
    cat help
elif [[ $1 == -c ]]; then
    op config
elif [[ $1 == update ]]; then
    ./libexec/init update $cookies_from_browser
elif [[ $1 == -p || $1 == -f || $1 == -pf ]]; then
    export temp=$(multi_file) && mkdir $temp
    if [[ $1 == -p ]]; then
        cp $HOME/"$local_path"/video_configs/$2 ./$temp/video_config
        export path_config=$2
        [[ -z $3 ]] && cat ./$temp/video_config || ./app "${@:3}"
    elif [[ $1 == -f ]]; then
        export load_code_force=$2
        ./app "${@:3}"
    elif [[ $1 == -pf ]]; then
        cp $HOME/"$local_path"/video_configs/$2 ./$temp/video_config
        export path_config=$2
        export load_code_force=$3        
        ./app "${@:4}"
    fi    
else
    export temp=$(multi_file) && mkdir $temp
    cp $HOME/"$local_path"/video_configs/$default ./$temp/video_config
    ./app $@
fi

[[ -d $temp ]] && rm -r $temp
set +f
