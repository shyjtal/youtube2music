#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
export tp="$SCRIPT_DIR/tools"
export ap="$SCRIPT_DIR"
cd "$SCRIPT_DIR"/app/youtube2music
source "$tp"/e2s config && source "$tp"/e2s system_config
export local_path="$HOME/$local_path"

if [[ $1 == "-version" || $1 == -v ]]; then
    "$tp"/config_opt system_config version
elif [[ $1 == -h ]]; then
    cat help
elif [[ $1 == -c ]]; then
    "$ap"/op config
elif [[ $1 == update ]]; then
    ./libexec/init update $cookies_from_browser
elif [[ $1 == -p || $1 == -f || $1 == -d* || $1 == -u || $1 != -* ]]; then
    export temp=$("$tp"/multi_file) && mkdir $temp
    [[ $1 == -p && $3 == -f ]] && ./libexec/preprocess_for_load -f "$4" -p "$2" "${@:5}" || ./libexec/preprocess_for_load "$@"
    [[ -d $temp ]] && rm -r $temp
else
    ./app "$@"
fi
